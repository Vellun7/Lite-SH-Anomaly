        <mxCell id="EE1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="IN1" target="MD2">
          <mxGeometry relative="1" as="geometry"/>
