        <mxCell id="EE10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="TH1" target="EOUT">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ========== RIGHT SECTION: INCREMENTAL LEARNING ========== -->

        <!-- SECTION TITLE -->
        <mxCell id="ST2" value="增量学习与概念漂移适配模块" style="text;html=1;strokeColor=#d79b00;fillColor=#ffe6cc;align=center;verticalAlign=middle;whiteSpace=wrap;spacing=4;fontSize=14;fontStyle=1;fontColor=#1D1D1F;fontFamily=Menlo;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="80" width="500" height="36" as="geometry"/>
        </mxCell>

        <!-- SLIDING WINDOW -->
        <mxCell id="IL1" value="滑动数据窗口&#xa;(W=500条)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="780" y="150" width="160" height="55" as="geometry"/>
        </mxCell>

        <!-- CONCEPT DRIFT DETECTION -->
        <mxCell id="IL2" value="概念漂移检测&#xa;(ADWIN简化版)" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="780" y="240" width="160" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="IL2N" value="|acc_window - acc_global| > \u03b5 ?&#xa;触发漂移告警" style="text;html=1;strokeColor=#d79b00;fillColor=#ffe6cc;align=center;verticalAlign=middle;whiteSpace=wrap;spacing=4;fontSize=9;fontColor=#1D1D1F;fontFamily=Menlo;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="950" y="245" width="180" height="40" as="geometry"/>
        </mxCell>

        <!-- THREE UPDATE STRATEGIES -->
        <mxCell id="IL3" value="策略1：全量重训练&#xa;新+历史样本合并重训" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="340" width="170" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="IL4" value="策略2：加权样本更新&#xa;新样本权重↑ 防止遗忘" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="900" y="340" width="170" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="IL5" value="策略3：集成式更新&#xa;新增子模型，保留历史" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="340" width="170" height="65" as="geometry"/>
        </mxCell>

        <!-- MODEL REGISTRY -->
        <mxCell id="IL6" value="模型注册中心&#xa;(版本管理 | 活动模型切换)" style="shape=cylinder3;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="800" y="460" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="IL6N" value="支持多版本并存&#xa;通过软链接指向活动模型" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;verticalAlign=middle;whiteSpace=wrap;spacing=4;fontSize=9;fontColor=#1D1D1F;fontFamily=Menlo;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="990" y="475" width="220" height="40" as="geometry"/>
        </mxCell>

        <!-- DEPLOYMENT MONITOR -->
        <mxCell id="IL7" value="性能监控器&#xa;(时延/内存/异常率)" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="730" y="580" width="160" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="IL8" value="自动更新器&#xa;(热更新/冷更新)" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="580" width="160" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="IL9" value="模型部署器&#xa;(持久化 | 验证 | 加载)" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1100" y="580" width="170" height="55" as="geometry"/>
        </mxCell>

        <!-- FINAL OUTPUT -->
        <mxCell id="IL10" value="更新后的活动模型&#xa;(重新加载至推理服务)" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="840" y="680" width="200" height="55" as="geometry"/>
        </mxCell>

        <!-- ===== CONNECTIONS: Incremental ===== -->
        <mxCell id="EI0" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="IL1" target="IL2">
