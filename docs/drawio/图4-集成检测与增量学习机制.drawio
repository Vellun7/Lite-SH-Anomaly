<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" version="21.0.0">
  <diagram id="ensemble-incremental" name="集成检测与增量学习机制">
    <mxGraphModel dx="1800" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- LEGEND -->
        <mxCell id="LG1" value="图例" style="text;html=1;strokeColor=#8E8E93;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;spacing=4;fontSize=12;fontStyle=1;fontColor=#1D1D1F;fontFamily=Menlo;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="80" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="LG2" value="输入" style="rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="130" y="28" width="40" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="LG3" value="处理" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="190" y="28" width="40" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="LG4" value="策略" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="250" y="18" width="50" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="LG5" value="增量模块" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="320" y="28" width="50" height="24" as="geometry"/>
        </mxCell>

        <!-- ========== LEFT SECTION: ENSEMBLE ========== -->

        <!-- SECTION TITLE: Ensemble Detection -->
        <mxCell id="ST1" value="集成检测模块" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;verticalAlign=middle;whiteSpace=wrap;spacing=4;fontSize=14;fontStyle=1;fontColor=#1D1D1F;fontFamily=Menlo;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="80" width="440" height="36" as="geometry"/>
        </mxCell>

        <!-- INPUT -->
        <mxCell id="IN1" value="样本 x&#xa;(14维特征)" style="rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="250" y="140" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- THREE MODELS -->
        <mxCell id="MD1" value="轻量化&#xa;孤立森林&#xa;score₁" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="230" width="130" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="MD2" value="轻量化&#xa;自编码器&#xa;score₂" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="230" width="130" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="MD3" value="KNN / SVM&#xa;(对比基线)&#xa;score₃" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="400" y="230" width="130" height="70" as="geometry"/>
        </mxCell>

        <!-- FUSION STRATEGIES -->
        <mxCell id="FS1" value="加权投票&#xa;w₁\u00b7score₁ + w₂\u00b7score₂ + w₃\u00b7score₃" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="350" width="150" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="FS2" value="软投票&#xa;(p₁+p₂+p₃)/3" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="350" width="130" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="FS3" value="多数投票&#xa;max count(label)" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="350" width="130" height="80" as="geometry"/>
        </mxCell>

        <!-- FUSION RESULT -->
        <mxCell id="FR" value="综合异常分数&#xa;S_ensemble = \u03b1\u00b7score₁ + \u03b2\u00b7score₂ + \u03b3\u00b7score₃&#xa;(\u03b1+\u03b2+\u03b3=1, 按F1权重分配)" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="470" width="240" height="70" as="geometry"/>
        </mxCell>

        <!-- ADAPTIVE THRESHOLD -->
        <mxCell id="TH1" value="自适应阈值调整" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="570" width="240" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="THN" value="FPR_recent > 1.5 \u00b7 FPR_base → \u03b8 += \u0394&#xa;FNR_recent > threshold → \u03b8 -= \u0394" style="text;html=1;strokeColor=#d79b00;fillColor=#ffe6cc;align=left;verticalAlign=top;whiteSpace=wrap;spacing=4;fontSize=9;fontColor=#1D1D1F;fontFamily=Menlo;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="640" width="380" height="45" as="geometry"/>
        </mxCell>

        <!-- ENSEMBLE OUTPUT -->
        <mxCell id="EOUT" value="集成输出&#xa;label + confidence + risk_score" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="700" width="240" height="55" as="geometry"/>
        </mxCell>

        <!-- ===== CONNECTIONS: Ensemble ===== -->
        <mxCell id="EE0" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="IN1" target="MD1">
          <mxGeometry relative="1" as="geometry"/>
