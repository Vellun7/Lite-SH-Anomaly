          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CROSS-SECTION: Ensemble → Incremental feedback -->
        <mxCell id="ECross" value="反馈：&#xa;性能下降时&#xa;触发更新" style="rounded=0;fillColor=#ffe6cc;strokeColor=#d79b00;dashed=1;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="640" width="80" height="60" as="geometry"/>
