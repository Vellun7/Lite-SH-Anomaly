        <mxCell id="PR2" value="(14, 4)" style="rounded=0;fillColor=#ffffff;strokeColor=#6c8ebf;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1">
