        <mxCell id="PS2" value="权重形状" style="text;html=1;strokeColor=#8E8E93;fillColor=#F2F2F7;align=center;verticalAlign=middle;whiteSpace=wrap;spacing=4;fontSize=11;fontStyle=1;fontColor=#1D1D1F;fontFamily=Menlo;" vertex="1" parent="1">
