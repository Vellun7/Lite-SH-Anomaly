<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" version="21.0.0">
  <diagram id="ae-arch" name="轻量化自编码器网络结构">
    <mxGraphModel dx="1800" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===== TITLE ===== -->
        <mxCell id="TITLE" value="轻量化自编码器网络结构（14→4→2→4→14）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;spacing=4;fontSize=16;fontStyle=1;fontColor=#1D1D1F;fontFamily=Menlo;" vertex="1" parent="1">
          <mxGeometry x="500" y="30" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== LEFT SIDE: Encoder ===== -->

        <!-- INPUT LAYER -->
        <mxCell id="IN1" value="输入层&#xa;x ∈ ℝ¹⁴" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="170" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- ARROW: Input to Hidden1 -->
        <mxCell id="A1" value="W₁₄ₓ₄ + b₁&#xa;(60 参数)&#xa;ReLU" style="text;html=1;strokeColor=#6c8ebf;fillColor=#ffffff;align=center;verticalAlign=middle;whiteSpace=wrap;spacing=4;fontSize=10;fontColor=#1D1D1F;fontFamily=Menlo;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="210" y="185" width="90" height="50" as="geometry"/>
        </mxCell>

        <!-- HIDDEN LAYER 1 -->
        <mxCell id="H1" value="隐藏层 h₁ ∈ ℝ⁴" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="310" y="170" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- ARROW: Hidden1 to Latent -->
        <mxCell id="A2" value="W₂₄ₓ₂ + b₂&#xa;(10 参数)&#xa;ReLU" style="text;html=1;strokeColor=#6c8ebf;fillColor=#ffffff;align=center;verticalAlign=middle;whiteSpace=wrap;spacing=4;fontSize=10;fontColor=#1D1D1F;fontFamily=Menlo;" vertex="1" parent="1">
          <mxGeometry x="440" y="185" width="90" height="50" as="geometry"/>
        </mxCell>

        <!-- LATENT SPACE -->
        <mxCell id="LZ" value="潜在空间&#xa;z ∈ ℝ²" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="170" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== RIGHT SIDE: Decoder ===== -->

        <!-- ARROW: Latent to Hidden2 -->
        <mxCell id="A3" value="W₃₂ₓ₄ + b₃&#xa;(12 参数)&#xa;ReLU" style="text;html=1;strokeColor=#6c8ebf;fillColor=#ffffff;align=center;verticalAlign=middle;whiteSpace=wrap;spacing=4;fontSize=10;fontColor=#1D1D1F;fontFamily=Menlo;" vertex="1" parent="1">
          <mxGeometry x="670" y="185" width="90" height="50" as="geometry"/>
        </mxCell>

        <!-- HIDDEN LAYER 2 -->
        <mxCell id="H2" value="隐藏层 h₂ ∈ ℝ⁴" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="770" y="170" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- ARROW: Hidden2 to Output -->
        <mxCell id="A4" value="W₄₄ₓ₁₄ + b₄&#xa;(70 参数)&#xa;Linear" style="text;html=1;strokeColor=#6c8ebf;fillColor=#ffffff;align=center;verticalAlign=middle;whiteSpace=wrap;spacing=4;fontSize=10;fontColor=#1D1D1F;fontFamily=Menlo;" vertex="1" parent="1">
          <mxGeometry x="900" y="185" width="90" height="50" as="geometry"/>
        </mxCell>

        <!-- OUTPUT LAYER -->
        <mxCell id="OUT" value="输出层&#xa;\u00e2x ∈ ℝ¹⁴" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1000" y="170" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== RECONSTRUCTION ERROR ===== -->
        <mxCell id="ERR" value="重构误差&#xa;r(x) = ||x - \u00e2x||²" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1000" y="280" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ELOSS" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="OUT" target="ERR">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== LOSS FUNCTION BOX ===== -->
        <mxCell id="LOSS" value="损失函数：MSE Loss&#xa;&#xa;\u004c_MSE = (1/N) \u00b7 \u03a3 ||x_i - \u00e2x_i||²&#xa;&#xa;仅在正常样本上训练" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="280" width="240" height="100" as="geometry"/>
        </mxCell>

        <!-- ===== ANOMALY DECISION ===== -->
        <mxCell id="DEC" value="异常判定&#xa;r(x) > \u03c4(95th percentile) → 异常" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="800" y="280" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="EDEC" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;dashed=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="ERR" target="DEC">
          <mxGeometry relative="1" as="geometry"/>
