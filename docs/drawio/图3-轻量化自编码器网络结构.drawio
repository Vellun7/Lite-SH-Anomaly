        <mxCell id="PR1" value="Input→h₁" style="rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1">
