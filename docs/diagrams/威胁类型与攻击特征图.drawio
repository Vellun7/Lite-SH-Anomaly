        <mxCell id="to_common4" value="" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=1.5;endFill=1;startFill=0;" edge="1" parent="1" source="threat4_features" target="common_header">
          <mxGeometry relative="0.5" as="geometry"/>
        </mxCell>
        <mxCell id="to_common5" value="" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=1.5;endFill=1;startFill=0;" edge="1" parent="1" source="threat5_features" target="common_header">
          <mxGeometry relative="0.5" as="geometry">
            <mxPoint x="1230" y="330" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- ===== 中间：通用检测特征体系 ===== -->
        <mxCell id="common_header" value="共性检测特征体系（流量行为层面）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#333333;fontColor=#ffffff;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="320" width="820" height="40" as="geometry"/>
        </mxCell>

        <!-- 六个通用特征 -->
        <mxCell id="feat1" value="连接持续时间&#10;duration" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b85450;strokeColor=#b85450;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="feat2" value="源端/目的端&#10;字节数&#10;orig_bytes&#10;resp_bytes" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d6b656;strokeColor=#d6b656;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="250" y="400" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="feat3" value="收发包数量&#10;orig_pkts&#10;resp_pkts" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=#82b366;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="400" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="feat4" value="协议类型&#10;protocol" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9673a6;strokeColor=#9673a6;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="590" y="400" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="feat5" value="连接状态&#10;conn_state" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#6c8ebf;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="760" y="400" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="feat6" value="数据速率&#10;data_rate" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0a7a0a;strokeColor=#0a7a0a;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="930" y="400" width="150" height="50" as="geometry"/>
        </mxCell>

        <!-- 共性说明 -->
        <mxCell id="common_note" value="以上五种攻击虽然表现形式不同，但均会引起这六项统计特征的变化" style="text;html=1;strokeColor=#333333;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#333333;italic=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="400" width="280" height="50" as="geometry"/>
        </mxCell>

        <!-- 指向检测方法 -->
        <mxCell id="arrow_down" value="" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;endFill=1;startFill=0;" edge="1" parent="1" source="feat3" target="method_box">
          <mxGeometry relative="0.5" as="geometry">
            <mxPoint x="600" y="500" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- ===== 底部：轻量化检测方法 ===== -->
        <mxCell id="method_box" value="【轻量化异常检测方法】&#xa;从流量行为层面对攻击模式进行抽象建模，建立稳定的基础特征体系&#xa;→ 不依赖复杂深度包检测 → 有效识别典型异常行为" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="490" width="820" height="80" as="geometry"/>
        </mxCell>

        <!-- 关键结论 -->
        <mxCell id="conclusion_box" value="关键结论：智能家居异常检测的关键不在于穷举所有攻击载荷内容，而在于从流量行为层面对攻击模式进行抽象建模。通过建立稳定的基础特征体系，可在不依赖复杂深度包检测的情况下，对典型异常行为进行有效识别。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="600" width="1260" height="60" as="geometry"/>
        </mxCell>

        <!-- 与传统网络对比 -->
        <mxCell id="compare_box" value="与传统办公网络对比" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="690" width="200" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="compare_content" value="智能家居网络攻击目标贴近日常生活 → 攻击后果直接影响家庭设备稳定运行和个人隐私安全&#xa;攻击类型更分散、协议更轻量、设备资源更受限 → 检测方法需适配轻量化需求" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="730" width="1260" height="50" as="geometry"/>
        </mxCell>

        <!-- ===== 图例 ===== -->
        <mxCell id="legend_bg" value="图例说明" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1380" y="60" width="120" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="legend_content" value="■ 红色 ─ DDoS / 共性特征&#xa;■ 黄色 ─ 端口扫描&#xa;■ 绿色 ─ 越权访问&#xa;■ 紫色 ─ 恶意指令/连接状态&#xa;■ 蓝色 ─ 僵尸网络/协议类型&#xa;■ 深色 ─ 检测特征体系标题" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1385" y="90" width="110" height="80" as="geometry"/>
