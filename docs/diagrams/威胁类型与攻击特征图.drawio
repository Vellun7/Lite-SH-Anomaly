<mxfile host="app.diagrams.net" modified="2026-04-05T20:19:00.000Z" agent="AI" version="24.0.0">
  <diagram name="威胁分类" uuid="threat01">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- 标题 -->
        <mxCell id="main_title" value="2.1.2 常见威胁类型与攻击特征" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="550" y="15" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== 顶部：智能家居网络安全威胁 ===== -->
        <mxCell id="top_header" value="智能家居网络安全威胁" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b85450;strokeColor=#b85450;fontColor=#ffffff;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="60" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- 五种攻击类型 -->
        <!-- 1. DDoS -->
        <mxCell id="threat1" value="分布式拒绝服务攻击&#10;DDoS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="140" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="threat1_features" value="【行为特征】&#xa;• 连接数快速上升&#xa;• 报文数量异常增长&#xa;• 通信字节数显著偏移" style="text;html=1;strokeColor=#b85450;fillColor=#fdf2f2;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="220" height="90" as="geometry"/>
        </mxCell>

        <!-- 2. 端口扫描 -->
        <mxCell id="threat2" value="端口扫描&#10;Port Scan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="140" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="threat2_features" value="【行为特征】&#xa;• 大量面向不同端口&#xa;  的高频试探行为&#xa;• 多目标地址扫描&#xa;• 短时大量连接尝试" style="text;html=1;strokeColor=#d6b656;fillColor=#fffef0;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="200" width="220" height="90" as="geometry"/>
        </mxCell>

        <!-- 3. 越权访问 -->
        <mxCell id="threat3" value="越权访问&#10;Unauthorized Access" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="140" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="threat3_features" value="【行为特征】&#xa;• 异常会话建立&#xa;• 非法身份调用&#xa;• 异常服务访问" style="text;html=1;strokeColor=#82b366;fillColor=#f0fff0;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="200" width="220" height="90" as="geometry"/>
        </mxCell>

        <!-- 4. 恶意控制指令 -->
        <mxCell id="threat4" value="恶意控制指令注入&#10;Malicious Command Injection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="140" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="threat4_features" value="【行为特征】&#xa;• 设备状态异常变化&#xa;• 与正常业务逻辑&#xa;  不一致的控制行为" style="text;html=1;strokeColor=#9673a6;fillColor=#f8f0ff;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="200" width="220" height="90" as="geometry"/>
        </mxCell>

        <!-- 5. 僵尸网络 -->
        <mxCell id="threat5" value="僵尸网络传播&#10;Botnet Propagation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1120" y="140" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="threat5_features" value="【行为特征】&#xa;• 异常外联通信&#xa;• 恶意程序传播行为&#xa;• 横向移动试探" style="text;html=1;strokeColor=#6c8ebf;fillColor=#f0f7ff;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="200" width="220" height="90" as="geometry"/>
        </mxCell>

