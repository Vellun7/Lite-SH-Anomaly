          <mxGeometry relative="0.5" as="geometry"/>
        </mxCell>
        <mxCell id="to_common3" value="" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=1.5;endFill=1;startFill=0;" edge="1" parent="1" source="threat3_features" target="common_header">
          <mxGeometry relative="0.5" as="geometry"/>
